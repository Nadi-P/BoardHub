<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/chess_background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/side_selector"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"

            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"

            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <Button
                android:id="@+id/btn_select_mode"
                android:fontFamily="@font/inter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                app:backgroundTint="@null"
                android:layout_marginBottom="8dp"
                android:background="@drawable/chess_gray_button_background"
                android:text="Select Mode"
                android:textAllCaps="false"
                android:textFontWeight="800"
                android:textSize="20dp"
                android:textColor="@color/chess_subtext_color"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- BLACK -->
                <FrameLayout
                    android:id="@+id/select_side_black"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:layout_marginRight="10dp"
                    android:background="@drawable/chess_green_button_background">

                    <FrameLayout
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:background="@drawable/chess_black_background"/>
                </FrameLayout>

                <!-- QUESTION MARK -->
                <FrameLayout
                    android:id="@+id/select_side_random"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:layout_margin="10dp"
                    android:background="@drawable/chess_green_button_background">

                    <FrameLayout
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:background="@drawable/chess_blackwhite_diagonal_background">
                    </FrameLayout>
                </FrameLayout>

                <!-- WHITE -->
                <FrameLayout
                    android:id="@+id/select_side_white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:layout_marginLeft="10dp"
                    android:background="@drawable/chess_green_button_background">

                    <FrameLayout
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:background="@drawable/chess_white_background"/>
                </FrameLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btn_start_game"
                android:fontFamily="@font/inter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:backgroundTint="@null"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:background="@drawable/chess_green_button_background"
                android:text="Start Game"
                android:textAllCaps="false"
                android:textFontWeight="900"
                android:textSize="20dp"
                android:textColor="@color/white"/>
        </LinearLayout>

        <TextView
            android:id="@+id/queueing_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:text="Queueing..."
            android:layout_margin="20dp"
            android:textSize="32dp"
            android:textFontWeight="500"
            android:textColor="@color/chess_subtext_color"/>


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>